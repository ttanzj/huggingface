// Sun-Panel Cloudflare Worker 代理
// 代理 https://huggingface.co/spaces/ttanzj/sun-panel

const ORIGIN = "https://ttanzj-sun-panel.hf.space";   // Hugging Face Space 的实际域名（推荐用 .hf.space）

addEventListener("fetch", (event) => {
  event.respondWith(handleRequest(event.request));
});

async function handleRequest(request) {
  const url = new URL(request.url);

  // 构建目标 URL
  let targetUrl = ORIGIN + url.pathname + url.search;

  // 克隆请求并修改必要的 Header
  const newRequest = new Request(targetUrl, {
    method: request.method,
    headers: new Headers(request.headers),
    body: request.body,
    redirect: "manual",   // 手动处理重定向，避免循环
  });

  // 重要 Header 修改（避免 HF 限制）
  newRequest.headers.set("Host", new URL(ORIGIN).host);
  newRequest.headers.set("Referer", ORIGIN);
  newRequest.headers.delete("CF-Connecting-IP");     // 可选：删除部分 Cloudflare Header
  newRequest.headers.delete("CF-IPCountry");
  newRequest.headers.delete("CF-RAY");

  try {
    let response = await fetch(newRequest);

    // 处理重定向（301/302/307/308）
    if ([301, 302, 307, 308].includes(response.status)) {
      const location = response.headers.get("Location");
      if (location) {
        // 如果重定向回 HF 域名，改成自己的域名
        let newLocation = location.replace(/https?:\/\/[^\/]+/, url.origin);
        const newHeaders = new Headers(response.headers);
        newHeaders.set("Location", newLocation);
        response = new Response(response.body, {
          status: response.status,
          statusText: response.statusText,
          headers: newHeaders,
        });
      }
    }

    // 复制响应并添加/修改 CORS 和安全 Header
    const newResponse = new Response(response.body, response);
    
    // 允许跨域（Gradio/Streamlit 等前端常需要）
    newResponse.headers.set("Access-Control-Allow-Origin", "*");
    newResponse.headers.set("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    newResponse.headers.set("Access-Control-Allow-Headers", "*");

    // 可选：添加安全 Header
    newResponse.headers.set("X-Content-Type-Options", "nosniff");
    newResponse.headers.set("X-Frame-Options", "SAMEORIGIN");

    return newResponse;

  } catch (err) {
    return new Response(`Proxy Error: ${err.message}`, { status: 502 });
  }
}
