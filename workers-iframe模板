export default {
  async fetch(request) {
    const url = new URL(request.url);
    // 目标 Hugging Face Space 的实际主机地址，用户名-项目名
    const targetHost = "***-***.hf.space";

    // ==================== 纯 if 嵌套路径判断 ====================
    if (url.pathname === "/" || url.pathname === "") {
      return handleProxy(request, targetHost, "/");
    } 
    else if (url.pathname.startsWith("/assets/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/static/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/gradio/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/queue/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/api/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/call/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/file=") || url.pathname.includes("/file/")) {
      return handleProxy(request, targetHost, url.pathname + url.search);
    } 
    else if (url.pathname.startsWith("/spaces/ttanz/sun")) {
      const newPath = url.pathname.replace("/spaces/ttanz/sun", "") || "/";
      return handleProxy(request, targetHost, newPath + url.search);
    } 
    else {
      // 兜底所有其他路径
      return handleProxy(request, targetHost, url.pathname + url.search);
    }
  }
};

// 基础代理函数（保持最简）
async function handleProxy(request, targetHost, targetPath) {
  const targetUrl = `https://${targetHost}${targetPath}`;

  const headers = new Headers(request.headers);
  headers.set("Host", targetHost);
  headers.set("Referer", `https://${targetHost}/`);

  if (request.method === "OPTIONS") {
    return new Response(null, {
      status: 204,
      headers: {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "*"
      }
    });
  }

  const response = await fetch(targetUrl, {
    method: request.method,
    headers: headers,
    body: request.body,
    redirect: "manual"
  });

  const newHeaders = new Headers(response.headers);
  newHeaders.set("Access-Control-Allow-Origin", "*");

  return new Response(response.body, {
    status: response.status,
    statusText: response.statusText,
    headers: newHeaders
  });
}
